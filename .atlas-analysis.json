  "keyFeatures": [
    "Spring WebFlux reactive microservices architecture",
    "JWT-based authentication and role-based access control via Spring Cloud Gateway",
    "Motel listing, room management, and reservation booking",
    "MercadoPago payment integration with OAuth and webhook support",
    "Email notification service for reservations and account events",
    "Cloudinary integration for motel and room image uploads",
    "Admin approval workflow for motel onboarding",
    "Hexagonal (ports-and-adapters) architecture per service",
    "PostgreSQL with R2DBC for fully non-blocking data access",
    "Docker Compose deployment with Azure-ready configuration"
  ],
